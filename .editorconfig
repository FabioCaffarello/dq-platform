root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# two trailing spaces in Markdown indicate a line break
trim_trailing_whitespace = false

[*.{yaml,yml,json}]
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab
